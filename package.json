{
  "name": "optimal-body-os",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "vite",
    "dev:api": "node --watch server/index.js",
    "auth:hash": "node server/hash-password.js",
    "start": "node server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "latest",
    "mongodb": "^7.4.0",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "^10.0.3",
    "typescript": "latest"
  }
}
